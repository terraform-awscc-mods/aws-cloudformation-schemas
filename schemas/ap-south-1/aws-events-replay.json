{
  "typeName" : "AWS::Events::Replay",
  "description" : "An EventBridge Replay replays archived events from an archive to an event bus.",
  "properties" : {
    "ReplayName" : {
      "type" : "string",
      "description" : "The name of the replay.",
      "minLength" : 1,
      "maxLength" : 64,
      "pattern" : "^[\\.\\-_A-Za-z0-9]+$"
    },
    "ReplayArn" : {
      "type" : "string",
      "description" : "The ARN of the replay.",
      "minLength" : 1,
      "maxLength" : 1600
    },
    "EventSourceArn" : {
      "type" : "string",
      "description" : "The ARN of the archive to replay events from.",
      "minLength" : 1,
      "maxLength" : 1600
    },
    "EventStartTime" : {
      "type" : "string",
      "description" : "A time stamp for the time to start replaying events.",
      "format" : "date-time"
    },
    "EventEndTime" : {
      "type" : "string",
      "description" : "A time stamp for the time to stop replaying events.",
      "format" : "date-time"
    },
    "Destination" : {
      "type" : "object",
      "description" : "A ReplayDestination object that includes details about the destination for the replay.",
      "properties" : {
        "Arn" : {
          "type" : "string",
          "description" : "The ARN of the event bus to replay events to.",
          "minLength" : 1,
          "maxLength" : 1600
        }
      },
      "required" : [ "Arn" ],
      "additionalProperties" : false
    },
    "State" : {
      "type" : "string",
      "description" : "The current state of the replay.",
      "enum" : [ "STARTING", "RUNNING", "CANCELLING", "COMPLETED", "CANCELLED", "FAILED" ]
    },
    "ReplayStartTime" : {
      "type" : "string",
      "description" : "A time stamp for the time that the replay started.",
      "format" : "date-time"
    }
  },
  "required" : [ "ReplayName", "EventSourceArn", "EventStartTime", "EventEndTime", "Destination" ],
  "additionalProperties" : false,
  "createOnlyProperties" : [ "/properties/Destination", "/properties/EventEndTime", "/properties/EventSourceArn", "/properties/EventStartTime", "/properties/ReplayName" ],
  "readOnlyProperties" : [ "/properties/ReplayArn", "/properties/State", "/properties/ReplayStartTime" ],
  "primaryIdentifier" : [ "/properties/ReplayArn" ],
  "additionalIdentifiers" : [ [ "/properties/ReplayName" ] ],
  "tagging" : {
    "taggable" : false
  },
  "handlers" : {
    "read" : {
      "permissions" : [ "events:DescribeReplay" ]
    },
    "list" : {
      "permissions" : [ "events:ListReplays" ]
    }
  }
}