{
  "typeName" : "AWS::IoT::Index",
  "description" : "Represents an AWS IoT fleet index, which enables searching and aggregating IoT device data.",
  "properties" : {
    "Arn" : {
      "type" : "string",
      "description" : "The Amazon Resource Name (ARN) of the index."
    },
    "IndexName" : {
      "type" : "string",
      "description" : "The index name.",
      "minLength" : 1,
      "maxLength" : 128,
      "pattern" : "^[a-zA-Z0-9:_-]+$"
    },
    "IndexStatus" : {
      "type" : "string",
      "description" : "The index status.",
      "enum" : [ "ACTIVE", "BUILDING", "REBUILDING" ]
    },
    "Schema" : {
      "type" : "string",
      "description" : "Contains a value that specifies the type of indexing performed."
    }
  },
  "additionalProperties" : false,
  "createOnlyProperties" : [ "/properties/IndexName" ],
  "readOnlyProperties" : [ "/properties/Arn", "/properties/IndexStatus", "/properties/Schema" ],
  "primaryIdentifier" : [ "/properties/Arn" ],
  "additionalIdentifiers" : [ [ "/properties/IndexName" ] ],
  "tagging" : {
    "taggable" : false
  },
  "handlers" : {
    "read" : {
      "permissions" : [ "iot:DescribeIndex" ]
    },
    "list" : {
      "permissions" : [ "iot:ListIndices" ]
    }
  }
}