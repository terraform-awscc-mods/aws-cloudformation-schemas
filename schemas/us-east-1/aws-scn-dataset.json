          "minItems" : 1,
          "maxItems" : 10
        }
      },
      "required" : [ "Fields" ]
    },
    "CreatedTime" : {
      "type" : "string",
      "format" : "date-time",
      "description" : "The creation time of the dataset."
    },
    "LastModifiedTime" : {
      "type" : "string",
      "format" : "date-time",
      "description" : "The last modified time of the dataset."
    },
    "Tags" : {
      "type" : "array",
      "description" : "The tags for the dataset.",
      "uniqueItems" : true,
