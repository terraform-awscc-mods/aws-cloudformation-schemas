          "type" : "string",
          "description" : "The name of the dataset schema.",
          "minLength" : 1,
          "maxLength" : 100,
          "pattern" : "^[A-Za-z0-9]+$"
        },
        "Fields" : {
          "type" : "array",
          "description" : "The list of field details of the dataset schema.",
          "items" : {
            "$ref" : "#/definitions/DataLakeDatasetSchemaField"
          },
          "minItems" : 1,
          "maxItems" : 500
        },
        "PrimaryKeys" : {
          "type" : "array",
