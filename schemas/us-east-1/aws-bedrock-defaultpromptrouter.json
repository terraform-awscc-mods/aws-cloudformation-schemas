    },
    "Type" : {
      "type" : "string",
      "description" : "The type of the prompt router.",
      "enum" : [ "custom", "default" ]
    },
    "CreatedAt" : {
      "type" : "string",
      "description" : "The timestamp when the default prompt router was created.",
      "format" : "date-time"
    },
    "UpdatedAt" : {
      "type" : "string",
      "description" : "The timestamp when the default prompt router was last updated.",
      "format" : "date-time"
