      "minLength" : 1,
      "maxLength" : 2048
    },
    "PromptRouterName" : {
      "type" : "string",
      "description" : "The name of the default prompt router.",
      "minLength" : 1,
      "maxLength" : 64,
      "pattern" : "^([0-9a-zA-Z][ _-]?)+$"
    },
    "Description" : {
      "type" : "string",
      "description" : "The description of the default prompt router.",
      "minLength" : 1,
      "maxLength" : 200,
      "pattern" : "^([0-9a-zA-Z:.][ _-]?)+$"
    },
