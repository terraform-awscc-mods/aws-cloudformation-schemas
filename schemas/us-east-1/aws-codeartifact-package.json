{
  "typeName" : "AWS::CodeArtifact::Package",
  "description" : "Resource Type definition for AWS::CodeArtifact::Package",
  "properties" : {
    "Arn" : {
      "type" : "string",
      "description" : "The ARN of the package.",
      "minLength" : 1,
      "maxLength" : 1011,
      "pattern" : "^\\S+$"
    },
    "DomainName" : {
      "type" : "string",
      "description" : "The name of the domain that contains the repository that contains the package.",
      "minLength" : 2,
      "maxLength" : 50,
      "pattern" : "^[a-z][a-z0-9\\-]{0,48}[a-z0-9]$"
    },
    "Repository" : {
      "type" : "string",
      "description" : "The name of the repository that contains the package.",
      "minLength" : 2,
      "maxLength" : 100,
      "pattern" : "^[A-Za-z0-9][A-Za-z0-9._\\-]{1,99}$"
    },
    "Format" : {
      "type" : "string",
      "description" : "The format of the package.",
      "enum" : [ "npm", "pypi", "maven", "nuget", "generic", "ruby", "swift", "cargo" ]
    },
    "Namespace" : {
      "type" : "string",
      "description" : "The namespace of the package.",
      "minLength" : 1,
      "maxLength" : 255,
      "pattern" : "^[^#/\\s]+$"
    },
    "Name" : {
      "type" : "string",
      "description" : "The name of the package.",
      "minLength" : 1,
      "maxLength" : 255,
      "pattern" : "^[^#/\\s]+$"
    },
    "OriginConfiguration" : {
      "type" : "object",
      "description" : "The package origin configuration for the package.",
      "properties" : {
        "Restrictions" : {
          "type" : "object",
          "description" : "The origin restrictions for the package.",
          "properties" : {
            "Publish" : {
              "type" : "string",
              "description" : "The package origin configuration that determines if new versions of the package can be published directly to the repository.",
              "enum" : [ "ALLOW", "BLOCK" ]
            },
            "Upstream" : {
              "type" : "string",
              "description" : "The package origin configuration that determines if new versions of the package can be added to the repository from an external connection or upstream source.",
              "enum" : [ "ALLOW", "BLOCK" ]
            }
          },
          "additionalProperties" : false
        }
      },
      "additionalProperties" : false
    }
  },
  "required" : [ "DomainName", "Repository", "Format", "Name" ],
  "additionalProperties" : false,
  "createOnlyProperties" : [ "/properties/DomainName", "/properties/Format", "/properties/Name", "/properties/Namespace", "/properties/Repository" ],
  "readOnlyProperties" : [ "/properties/Arn", "/properties/OriginConfiguration" ],
  "primaryIdentifier" : [ "/properties/Arn" ],
  "additionalIdentifiers" : [ [ "/properties/DomainName", "/properties/Repository", "/properties/Format", "/properties/Namespace", "/properties/Name" ] ],
  "tagging" : {
    "taggable" : false
  },
  "handlers" : {
    "read" : {
      "permissions" : [ "codeartifact:DescribePackage" ]
    },
    "list" : {
      "handlerSchema" : {
        "properties" : {
          "DomainName" : {
            "type" : "string",
            "minLength" : 2,
            "maxLength" : 50,
            "pattern" : "^[a-z][a-z0-9\\-]{0,48}[a-z0-9]$"
          },
          "Repository" : {
            "type" : "string",
            "minLength" : 2,
            "maxLength" : 100,
            "pattern" : "^[A-Za-z0-9][A-Za-z0-9._\\-]{1,99}$"
          }
        },
        "required" : [ "DomainName", "Repository" ]
      },
      "permissions" : [ "codeartifact:ListPackages" ]
    }
  }
}