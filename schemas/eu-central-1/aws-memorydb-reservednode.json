{
  "typeName" : "AWS::MemoryDB::ReservedNode",
  "description" : "Represents a MemoryDB reserved node purchased via PurchaseReservedNodesOffering. Reserved nodes are not eligible for cancellation and are non-refundable.",
  "properties" : {
    "Arn" : {
      "type" : "string",
      "description" : "The Amazon Resource Name (ARN) of the reserved node."
    },
    "ReservationId" : {
      "type" : "string",
      "description" : "A customer-specified identifier to track this reservation."
    },
    "ReservedNodesOfferingId" : {
      "type" : "string",
      "description" : "The ID of the reserved node offering to purchase."
    },
    "NodeType" : {
      "type" : "string",
      "description" : "The node type for the reserved nodes."
    },
    "Duration" : {
      "type" : "integer",
      "description" : "The duration of the reservation in seconds."
    },
    "FixedPrice" : {
      "type" : "number",
      "description" : "The fixed price charged for this reserved node."
    },
    "NodeCount" : {
      "type" : "integer",
      "description" : "The number of nodes that have been reserved."
    },
    "OfferingType" : {
      "type" : "string",
      "description" : "The offering type of this reserved node."
    },
    "State" : {
      "type" : "string",
      "description" : "The state of the reserved node."
    },
    "StartTime" : {
      "type" : "string",
      "format" : "date-time",
      "description" : "The time the reservation started."
    },
    "RecurringCharges" : {
      "type" : "array",
      "description" : "The recurring price charged to run this reserved node.",
      "items" : {
        "$ref" : "#/definitions/RecurringCharge"
      },
      "insertionOrder" : false
    },
    "Tags" : {
      "type" : "array",
      "description" : "A list of tags to be added to this resource.",
      "items" : {
        "$ref" : "#/definitions/Tag"
      },
      "insertionOrder" : false,
      "uniqueItems" : true
    }
  },
  "definitions" : {
    "RecurringCharge" : {
      "type" : "object",
      "properties" : {
        "RecurringChargeAmount" : {
          "type" : "number",
          "description" : "The amount of the recurring charge."
        },
        "RecurringChargeFrequency" : {
          "type" : "string",
          "description" : "The frequency of the recurring charge."
        }
      },
      "additionalProperties" : false
    },
    "Tag" : {
      "type" : "object",
      "properties" : {
        "Key" : {
          "type" : "string",
          "description" : "The key of the tag.",
          "minLength" : 1,
          "maxLength" : 128
        },
        "Value" : {
          "type" : "string",
          "description" : "The value of the tag.",
          "minLength" : 0,
          "maxLength" : 256
        }
      },
      "required" : [ "Key", "Value" ],
      "additionalProperties" : false
    }
  },
  "readOnlyProperties" : [ "/properties/Arn", "/properties/ReservationId", "/properties/ReservedNodesOfferingId", "/properties/NodeType", "/properties/Duration", "/properties/FixedPrice", "/properties/NodeCount", "/properties/OfferingType", "/properties/State", "/properties/StartTime", "/properties/RecurringCharges", "/properties/Tags" ],
  "primaryIdentifier" : [ "/properties/Arn" ],
  "additionalIdentifiers" : [ [ "/properties/ReservationId" ] ],
  "additionalProperties" : false,
  "tagging" : {
    "taggable" : true,
    "tagOnCreate" : false,
    "tagUpdatable" : false,
    "cloudFormationSystemTags" : false,
    "tagProperty" : "/properties/Tags",
    "permissions" : [ "memorydb:ListTags" ]
  },
  "handlers" : {
    "read" : {
      "permissions" : [ "memorydb:DescribeReservedNodes", "memorydb:ListTags" ]
    },
    "list" : {
      "permissions" : [ "memorydb:DescribeReservedNodes" ]
    }
  }
}