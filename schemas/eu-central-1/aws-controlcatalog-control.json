{
  "typeName" : "AWS::ControlCatalog::Control",
  "description" : "Returns details about a control from the AWS Control Catalog, including its name, description, behavior, severity, region configuration, and implementation details.",
  "properties" : {
    "Arn" : {
      "type" : "string",
      "description" : "The Amazon Resource Name (ARN) of the control.",
      "minLength" : 34,
      "maxLength" : 2048,
      "pattern" : "^arn:(aws(?:[-a-z]*)?):(controlcatalog|controltower):[a-zA-Z0-9-]*::control/[0-9a-zA-Z_\\-]+$"
    },
    "ControlId" : {
      "type" : "string",
      "description" : "The unique opaque identifier of the control.",
      "pattern" : "^[0-9a-zA-Z_\\-]+$"
    },
    "Name" : {
      "type" : "string",
      "description" : "The display name of the control."
    },
    "Description" : {
      "type" : "string",
      "description" : "A description of what the control does."
    },
    "Behavior" : {
      "type" : "string",
      "description" : "A term that identifies the control's functional behavior.",
      "enum" : [ "PREVENTIVE", "PROACTIVE", "DETECTIVE" ]
    },
    "Severity" : {
      "type" : "string",
      "description" : "The severity of the control.",
      "enum" : [ "LOW", "MEDIUM", "HIGH", "CRITICAL" ]
    },
    "RegionConfiguration" : {
      "$ref" : "#/definitions/RegionConfiguration"
    },
    "Implementation" : {
      "$ref" : "#/definitions/ImplementationDetails"
    },
    "Aliases" : {
      "type" : "array",
      "description" : "A list of alternative identifiers for the control.",
      "items" : {
        "type" : "string",
        "pattern" : "^[a-zA-Z0-9](?:[a-zA-Z0-9_.-]{0,254}[a-zA-Z0-9])$"
      },
      "insertionOrder" : false
    },
    "CreateTime" : {
      "type" : "string",
      "description" : "A timestamp that notes the time when the control was released.",
      "format" : "date-time"
    },
    "GovernedResources" : {
      "type" : "array",
      "description" : "A list of AWS resource types that are governed by this control.",
      "items" : {
        "type" : "string",
        "pattern" : "^[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}$"
      },
      "insertionOrder" : false
    }
  },
  "definitions" : {
    "RegionConfiguration" : {
      "type" : "object",
      "description" : "Information about the control's region configuration.",
      "properties" : {
        "Scope" : {
          "type" : "string",
          "description" : "The scope of the control.",
          "enum" : [ "GLOBAL", "REGIONAL" ]
        },
        "DeployableRegions" : {
          "type" : "array",
          "description" : "Regions in which the control is available to be deployed.",
          "items" : {
            "type" : "string",
            "pattern" : "^[a-zA-Z0-9-]{1,128}$"
          },
          "insertionOrder" : false
        }
      },
      "required" : [ "Scope" ],
      "additionalProperties" : false
    },
    "ImplementationDetails" : {
      "type" : "object",
      "description" : "An object that describes the implementation type for a control.",
      "properties" : {
        "Type" : {
          "type" : "string",
          "description" : "A string that describes a control's implementation type.",
          "minLength" : 7,
          "maxLength" : 2048,
          "pattern" : "^[A-Za-z0-9]+(::[A-Za-z0-9_]+){2,3}$"
        },
        "Identifier" : {
          "type" : "string",
          "description" : "A service-specific identifier for the control.",
          "minLength" : 1,
          "maxLength" : 256,
          "pattern" : "^[a-zA-Z0-9_\\.-]+$"
        }
      },
      "required" : [ "Type" ],
      "additionalProperties" : false
    }
  },
  "additionalProperties" : false,
  "readOnlyProperties" : [ "/properties/Arn", "/properties/ControlId", "/properties/Name", "/properties/Description", "/properties/Behavior", "/properties/Severity", "/properties/RegionConfiguration", "/properties/Implementation", "/properties/Aliases", "/properties/CreateTime", "/properties/GovernedResources" ],
  "primaryIdentifier" : [ "/properties/Arn" ],
  "additionalIdentifiers" : [ [ "/properties/ControlId" ] ],
  "tagging" : {
    "taggable" : false
  },
  "handlers" : {
    "read" : {
      "permissions" : [ "controlcatalog:GetControl" ]
    },
    "list" : {
      "permissions" : [ "controlcatalog:ListControls" ]
    }
  }
}