{
  "typeName" : "AWS::GreengrassV2::CoreDevice",
  "description" : "Represents a Greengrass core device, which is an IoT thing that runs the IoT Greengrass Core software.",
  "properties" : {
    "Arn" : {
      "type" : "string",
      "description" : "The ARN of the core device.",
      "pattern" : "^arn:[^:]*:greengrass:[^:]*:[0-9]+:coreDevices:.+$"
    },
    "CoreDeviceThingName" : {
      "type" : "string",
      "description" : "The name of the core device. This is also the name of the IoT thing.",
      "minLength" : 1,
      "maxLength" : 128
    },
    "CoreVersion" : {
      "type" : "string",
      "description" : "The version of the IoT Greengrass Core software that the core device runs.",
      "minLength" : 1,
      "maxLength" : 255
    },
    "Platform" : {
      "type" : "string",
      "description" : "The operating system platform that the core device runs.",
      "minLength" : 1,
      "maxLength" : 255
    },
    "Architecture" : {
      "type" : "string",
      "description" : "The computer architecture of the core device.",
      "minLength" : 1,
      "maxLength" : 255
    },
    "Runtime" : {
      "type" : "string",
      "description" : "The runtime for the core device. The runtime can be aws_nucleus_classic or aws_nucleus_lite.",
      "minLength" : 1,
      "maxLength" : 255
    },
    "Status" : {
      "type" : "string",
      "description" : "The status of the core device.",
      "enum" : [ "HEALTHY", "UNHEALTHY" ]
    },
    "LastStatusUpdateTimestamp" : {
      "type" : "string",
      "format" : "date-time",
      "description" : "The time at which the core device's status last updated, expressed in ISO 8601 format."
    },
    "Tags" : {
      "type" : "array",
      "description" : "Tags associated with the core device.",
      "items" : {
        "type" : "object",
        "properties" : {
          "Key" : {
            "type" : "string",
            "minLength" : 1,
            "maxLength" : 128
          },
          "Value" : {
            "type" : "string",
            "minLength" : 0,
            "maxLength" : 256
          }
        },
        "required" : [ "Key", "Value" ],
        "additionalProperties" : false
      },
      "maxItems" : 200
    }
  },
  "additionalProperties" : false,
  "createOnlyProperties" : [ "/properties/CoreDeviceThingName" ],
  "readOnlyProperties" : [ "/properties/Arn", "/properties/CoreVersion", "/properties/Platform", "/properties/Architecture", "/properties/Runtime", "/properties/Status", "/properties/LastStatusUpdateTimestamp", "/properties/Tags" ],
  "primaryIdentifier" : [ "/properties/Arn" ],
  "additionalIdentifiers" : [ [ "/properties/CoreDeviceThingName" ] ],
  "tagging" : {
    "taggable" : true,
    "tagOnCreate" : false,
    "tagUpdatable" : false,
    "cloudFormationSystemTags" : false,
    "tagProperty" : "/properties/Tags",
    "permissions" : [ "greengrass:ListTagsForResource" ]
  },
  "handlers" : {
    "read" : {
      "permissions" : [ "greengrass:GetCoreDevice", "greengrass:ListTagsForResource" ]
    },
    "list" : {
      "permissions" : [ "greengrass:ListCoreDevices" ]
    }
  }
}